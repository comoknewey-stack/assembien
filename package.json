{
  "name": "assem",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*",
    "integrations/*",
    "providers/*"
  ],
  "scripts": {
    "dev": "concurrently -n agent,desktop -c cyan,green \"npm run dev:agent\" \"npm run dev:desktop\"",
    "dev:agent": "npm run dev --workspace @assem/local-agent",
    "dev:desktop": "npm run dev --workspace @assem/desktop",
    "dev:desktop:app": "concurrently -k -n agent,tauri -c cyan,green \"npm run dev:agent\" \"npm run dev:desktop:tauri\"",
    "dev:desktop:tauri": "wait-on http-get://127.0.0.1:4318/api/health && npm run tauri:dev --workspace @assem/desktop",
    "build": "npm run typecheck && npm run build --workspace @assem/local-agent && npm run build --workspace @assem/desktop",
    "build:desktop": "npm run tauri:build --workspace @assem/desktop",
    "doctor:desktop": "npm run tauri:info --workspace @assem/desktop",
    "doctor:voice": "tsx scripts/doctor-voice.ts",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.browser.json --noEmit",
    "test": "vitest run",
    "voice:bootstrap": "tsx scripts/bootstrap-whisper-runtime.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.3",
    "wait-on": "^8.0.5"
  }
}
