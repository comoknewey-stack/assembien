{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ASSEM",
  "version": "0.1.0",
  "identifier": "com.assem.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ASSEM",
        "width": 1480,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:4318 http://localhost:4318 ws://127.0.0.1:4318 ws://localhost:4318"
    }
  },
  "bundle": {
    "active": false
  }
}
