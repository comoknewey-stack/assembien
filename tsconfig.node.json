{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "apps/local-agent/**/*.ts",
    "packages/**/*.ts",
    "integrations/**/*.ts",
    "providers/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "apps/desktop/**/*",
    "packages/sdk/**/*",
    "**/dist",
    "**/node_modules"
  ]
}
